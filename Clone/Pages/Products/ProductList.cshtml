@page
@model Indotalent.Pages.Products.ProductCategoryReportModel
@{
    Layout = "~/Pages/Shared/AdminLTE/_Admin.cshtml";
    ViewData["Title"] = "Product Category Report";
}

<div class="row mb-3">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-boxes mr-1"></i> Product Category Report
                </h3>
            </div>
            <div class="card-body pb-2">
                <div class="row align-items-end">

                    <div class="col-md-6">
                        <label class="form-label">Category</label>
                        <select id="ddlCategory" class="form-control select2">
                            @foreach (var opt in Model.CategoryOptions)
                            {
                                <option value="@opt.Value">@opt.Text</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Category Code</label>
                        <input type="text" id="txtCategoryCode" class="form-control"
                               placeholder="" />
                    </div>

                    <div class="col-md-3 d-flex gap-2 mt-1">
                        <button id="btnFilter" class="btn btn-primary w-100">
                            <i class="fas fa-search mr-1"></i> Filter
                        </button>
                        <button id="btnAll" class="btn btn-secondary w-100">
                            <i class="fas fa-list mr-1"></i> All
                        </button>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div id="Grid"></div>
    </div>
</div>

<div class="modal fade" id="mdlProductDetail" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-md" role="document">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fas fa-info-circle mr-1"></i> Product Detail Card</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <table class="table table-sm table-bordered">
                    <tr><th class="w-35 bg-light">Product ID:</th><td id="lblProdId"></td></tr>
                    <tr><th class="bg-light">Product Name:</th><td id="lblProdName"></td></tr>
                    <tr><th class="bg-light">Barcode:</th><td id="lblBarcode"></td></tr>
                    <tr><th class="bg-light">Sales Price:</th><td id="lblPrice" class="text-danger font-weight-bold"></td></tr>
                    <tr><th class="bg-light">Unit:</th><td id="lblUnit"></td></tr>
                    <tr><th class="bg-light">Description:</th><td id="lblDesc"></td></tr>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var grid;

        document.addEventListener('DOMContentLoaded', function () {

            if ($.fn.select2) {
                $('#ddlCategory').select2({ width: '100%' });
            }

            grid = new ej.grids.Grid({
                allowFiltering: true,
                allowSorting: true,
                allowGrouping: false,
                allowTextWrap: true,
                allowResizing: true,
                allowPaging: true,
                allowSelection: true,
                allowExcelExport: true,

                filterSettings: { type: 'CheckBox' },

                pageSettings: {
                    currentPage: 1,
                    pageSize: 50,
                    pageSizes: ["20", "50", "100", "200", "All"]
                },

                showColumnMenu: true,
                gridLines: 'Horizontal',

                rowSelected: function (args) {
            var rowData = args.data;
            var prodId = rowData.ProductId;
            var compCode = rowData.CompanyCode;

            if (!prodId || !compCode) return;

            var detailUrl = '/Products/ProductDetail?productId=' + encodeURIComponent(prodId) + '&companyCode=' + encodeURIComponent(compCode);
            window.location.href = detailUrl;
        },

                columns: [
                    {
                        field: 'CompanyCode',
                        headerText: 'Company',
                        width: 100
                    },
                    {
                        field: 'ProductId',
                        headerText: 'Product ID',
                        width: 120,
                        isPrimaryKey: true
                    },
                    {
                        field: 'ProductName',
                        headerText: 'Product Name',
                        width: 250
                    },
                    {
                        field: 'CategoryCode',
                        headerText: 'Category Code',
                        width: 160
                    },
                    {
                        field: 'CategoryName',
                        headerText: 'Category Name',
                        width: 220
                    },
                    {
                        field: 'ParentCategoryName',
                        headerText: 'Parent Category',
                        width: 200
                    },
                    {
                        field: 'CategoryHierarchyName',
                        headerText: 'Hierarchy',
                        width: 100
                    }
                ],

                toolbar: ['ExcelExport', 'Search'],

                toolbarClick: (args) => {
                    if (args.item.id === 'Grid_excelexport') {
                        grid.excelExport();
                    }
                },

                actionFailure: (args) => {
                    console.error('Grid error:', args);
                }
            });

            grid.appendTo('#Grid');

            // wire up buttons
            document.getElementById('btnFilter').addEventListener('click', function () {
                loadGrid();
            });

            document.getElementById('btnAll').addEventListener('click', function () {
                $('#ddlCategory').val('').trigger('change');
                document.getElementById('txtCategoryCode').value = '';
                loadGrid();
            });
        });

        function loadGrid() {
            var recId    = $('#ddlCategory').val();
            var code     = document.getElementById('txtCategoryCode').value.trim();

            var params = new URLSearchParams();
            params.append('handler', 'Products');
            if (recId)  params.append('CategoryRecId', recId);
            if (code)   params.append('CategoryCode', code);

            var url = '/Products/ProductList?' + params.toString();

            // show loading
            grid.showSpinner();

            fetch(url, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(r => r.json())
            .then(data => {
                grid.dataSource = data;
                grid.hideSpinner();
            })
            .catch(err => {
                console.error('Load failed:', err);
                grid.hideSpinner();
            });
        }
    </script>
}