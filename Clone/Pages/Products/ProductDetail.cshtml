@page
@model Indotalent.Pages.Products.ProductDetailModel
@{
    Layout = "~/Pages/Shared/AdminLTE/_Admin.cshtml";
    ViewData["Title"] = "Product Management Detail";
}

<div class="row mb-3">
    <div class="col-12">
        <a href="/Products/ProductList" class="btn btn-secondary btn-sm mb-3">
            <i class="fas fa-arrow-left mr-1"></i> Back to List
        </a>

        <!-- ẨN ALERT CŨ, SẼ HIỂN THỊ BẰNG TOAST - Có thể xóa nếu cần -->
        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert" style="display:none;">
                <i class="fas fa-check-circle mr-1"></i> @Model.StatusMessage
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        <!-- Main Content: 8:2 với chiều cao cố định 700px -->
        <div class="row d-flex align-items-stretch" style="height: 700px; max-height: 700px;">
            
            <!-- Form (80%) - Có scroll riêng -->
            <div class="col-lg-10 col-md-12 d-flex" style="height: 700px; max-height: 700px;">
                <div class="card card-primary card-outline w-100" style="height: 700px; max-height: 700px; display: flex; flex-direction: column;">
                    <div class="card-header">
                        <!-- ===== HÀNG 1: TIÊU ĐỀ ===== -->
                        <div class="d-flex justify-content-between align-items-center">
                            <h3 class="card-title mb-0">
                                <i class="fas fa-box-open mr-1"></i> Modify Product Information
                            </h3>
                        </div>

                        <!-- ===== ĐƯỜNG GẠCH NGANG PHÂN CÁCH ===== -->
                        <hr class="detail-divider" />

                        <!-- ===== HÀNG 2: ACTION BUTTONS ===== -->
                        <div class="action-buttons">
                            <button type="button" id="btnCreate" class="btn btn-success btn-sm">
                                <i class="fas fa-plus mr-1"></i> Create
                            </button>
                            <button type="button" id="btnEdit" class="btn btn-warning btn-sm">
                                <i class="fas fa-edit mr-1"></i> Edit
                            </button>
                            <button type="button" id="btnDelete" class="btn btn-danger btn-sm">
                                <i class="fas fa-trash mr-1"></i> Delete
                            </button>
                        <!-- GIỮ NGUYÊN btnSubmit, giữ Id theo logic cũ, chỉ disabled vào -->
                            <button type="submit" id="btnSubmit" class="btn btn-primary btn-sm" disabled>
                                <i class="fas fa-save mr-1"></i> Save Updates
                            </button>
                        </div>
                    </div>

                    <!-- Form có scroll dọc riêng -->
                    <div style="overflow-y: auto; flex: 1;">
                        <form id="formMain" method="post" novalidate>
                            <div class="card-body">
                                <!-- ===== SECTION 1: GENERAL ===== -->
                                <div class="form-section">
                                    <h5 class="form-section-title">General</h5>
                                    <hr class="form-section-divider" />
                                    <div class="row">
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label class="form-label">Company Code<span class="text-danger">*</span></label>
                                                <!-- THÊM CLASS readonly-always ĐỂ KHÔNG BAO GIỜ ĐƯỢC CHỈNH SỬA -->
                                                <input type="text" asp-for="Product.CompanyCode" class="form-control readonly-always" readonly />
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label class="form-label">Product ID<span class="text-danger">*</span></label>
                                                <!-- THÊM CLASS readonly-always ĐỂ KHÔNG BAO GIỜ ĐƯỢC CHỈNH SỬA -->
                                                <input type="text" asp-for="Product.ProductId" class="form-control readonly-always" readonly />
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label class="form-label">Product Name</label>
                                                <input type="text" asp-for="Product.ProductName" class="form-control" readonly />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- ===== SECTION 2: CATEGORY ===== -->
                                <div class="form-section mt-4">
                                    <h5 class="form-section-title">Category</h5>
                                    <hr class="form-section-divider" />
                                    <div class="row">
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label class="form-label">Category Code</label>
                                                <input type="text" id="txtCategoryCode" class="form-control" readonly />
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label class="form-label">Category Name</label>
                                                <input type="text" id="txtCategoryName" class="form-control" readonly />
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label class="form-label">Parent Category</label>
                                                <input type="text" id="txtParentCategory" class="form-control" readonly />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- ===== SECTION 3: INVOICING ===== -->
                                <div class="form-section mt-4">
                                    <h5 class="form-section-title">Invoicing</h5>
                                    <hr class="form-section-divider" />
                                    <div class="row">
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label class="form-label">Barcode Identification</label>
                                                <input type="text" asp-for="Product.Barcode" class="form-control" readonly />
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label class="form-label">Sales Price (VND)</label>
                                                <input type="number" step="0.01" asp-for="Product.SalesPrice" class="form-control" readonly />
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label class="form-label">Unit of Measure</label>
                                                <select asp-for="Product.UnitOfMeasure" class="form-control select2" disabled>
                                                    <option value="">-- Select Unit --</option>
                                                    @foreach (var unit in Model.UnitOptions)
                                                    {
                                                        <option value="@unit">@unit</option>
                                                    }
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- ===== SECTION 4: DESCRIPTION ===== -->
                                <div class="form-section mt-4">
                                    <h5 class="form-section-title">Description</h5>
                                    <hr class="form-section-divider" />
                                    <div class="row">
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label class="form-label">Voucher</label>
                                                <input type="text" id="txtVoucher" class="form-control" readonly />
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label class="form-label">Details</label>
                                                <input type="text" id="txtDetails" class="form-control" readonly />
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label class="form-label">Hierarchy</label>
                                                <input type="text" id="txtHierarchy" class="form-control" readonly />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="form-group">
                                                <label class="form-label">Extended Description</label>
                                                <textarea asp-for="Product.ProductDescription" class="form-control" rows="3" readonly></textarea>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- XÓA CARD-FOOTER CŨ - Nút Save Updates đã được chuyển lên header -->
                            <!-- <div class="card-footer d-flex justify-content-end gap-2">
                                <button type="submit" id="btnSubmit" class="btn btn-primary px-4">
                                    <i class="fas fa-save mr-1"></i> Save Updates
                                </button>
                            </div> -->
                        </form>
                    </div>
                </div>
            </div>

            <!-- Detail Card - Có scroll riêng -->
            <div class="col-lg-2 col-md-12 mt-3 mt-lg-0 d-flex" style="height: 700px; max-height: 700px;">
                <div class="card card-primary card-outline w-100" style="height: 700px; max-height: 700px; display: flex; flex-direction: column;">
                    <div class="card-header py-2">
                        <h6 class="card-title mb-0">
                            <i class="fas fa-info-circle mr-1"></i> Detail
                        </h6>
                    </div>
                    <!-- Detail Card có scroll dọc riêng -->
                    <div class="card-body p-2" id="detailContent" style="overflow-y: auto; flex: 1;">
                        <!-- ===== ITEM INVENTORY ===== -->
                        <div class="detail-section">
                            <div class="detail-section-header">
