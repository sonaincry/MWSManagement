@page
@model Indotalent.Pages.LogSessions.RetailTransactionListModel
@{
    Layout = "~/Pages/Shared/AdminLTE/_Admin.cshtml";
    ViewData["Module"] = "Log";
}




<div class="row">
    <div class="col-12">
        <div id="Grid"></div>
    </div>
</div>

@section Scripts {
    <script>


        document.addEventListener('DOMContentLoaded', function () {

            var grid = new ej.grids.Grid({
                dataSource: new ej.data.DataManager({
                    url: '/odata/RetailTransaction',
                    adaptor: new ej.data.ODataV4Adaptor()
                }),

                allowFiltering: true,
                allowSorting: true,
                allowGrouping: true,
                allowTextWrap: true,
                allowResizing: true,
                allowPaging: true,
                allowSelection: true,
                allowExcelExport: true,

                filterSettings: { type: 'CheckBox' },

                sortSettings: {
                    columns: [{
                        field: 'CreatedDate',
                        direction: 'Descending'
                    }]
                },

                pageSettings: {
                    currentPage: 1,
                    pageSize: 20,
                    pageSizes: ["10", "20", "50", "100", "200", "All"]
                },

                selectionSettings: {
                    persistSelection: true,
                    type: 'Single'
                },

                autoFit: true,
                showColumnMenu: true,
                gridLines: 'Horizontal',

                columns: [

                    {
                        field: 'TransactionId',
                        isPrimaryKey: true,
                        headerText: 'Transaction ID',
                        width: 210
                    },

                    {
                        field: 'Type',
                        width: 90,
                        textAlign: 'Center'
                    },

                    {
                        field: 'ReceiptId',
                        headerText: 'Receipt ID',
                        width: 180
                    },

                    {
                        field: 'Store',
                        width: 120
                    },

                    {
                        field: 'Terminal',
                        width: 120
                    },

                    {
                        field: 'Staff',
                        width: 120
                    },

                    {
                        field: 'TransDate',
                        headerText: 'Transaction Date',
                        width: 150,
                        type: 'dateTime',
                        format: 'dd-MM-yyyy'
                    },

                    {
                        field: 'NetAmount',
                        width: 150,
                        type: 'number',
                        textAlign: 'Right',
                        format: 'N2'
                    },

                    {
                        field: 'GrossAmount',
                        width: 150,
                        type: 'number',
                        textAlign: 'Right',
                        format: 'N2'
                    },

                    {
                        field: 'PaymentAmount',
                        width: 120,
                        type: 'number',
                        textAlign: 'Right',
                        format: 'N2'
                    },

                    {
                        field: 'NumberOfItems',
                        width: 120,
                        textAlign: 'Center'
                    },
                    {
                        field: 'TransDateSearch',
                        visible: false
                    }

                    // {
                    //     field: 'CreatedDate',
                    //     width: 150,
                    //     type: 'dateTime',
                    //     format: 'yyyy-MM-dd HH:mm:ss'
                    // }
                ],

                toolbar: [
                    'ExcelExport',
                    'Search'
                ],

                dataBound: function () {
                    grid.autoFitColumns([
                        'TransactionId',
                        'Type',
                        'ReceiptId',
                        'Store',
                        'Terminal',
                        'Staff',
                        'TransDate',
                        'NetAmount',
                        'GrossAmount',
                        'PaymentAmount',
                        'NumberOfItems',
                        'CreatedDate'
                    ]);
                },

                toolbarClick: (args) => {
                    if (args.item.id === 'Grid_excelexport') {
                        grid.excelExport();
                    }
                },

                actionFailure: (args) => {
                    console.log(args);
                }
            });

            grid.appendTo('#Grid');

        });
    </script>
}