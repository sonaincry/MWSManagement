@page
@model Indotalent.Pages.Products.UnitOfMeasureListModel
@{
    Layout = "~/Pages/Shared/AdminLTE/_Admin.cshtml";
    ViewData["Title"] = "Unit of Measure Settings";
}

@Html.AntiForgeryToken() <div class="row">
    <div class="col-12">
        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            <div class="alert alert-info alert-dismissible fade show" role="alert">
                <i class="fas fa-info-circle mr-1"></i> @Model.StatusMessage
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        <div class="card card-primary card-outline">
            <div class="card-header d-flex align-items-center justify-content-between">
                <h3 class="card-title m-0">
                    <i class="fas fa-balance-scale mr-1"></i> Global Unit of Measure Configurations
                </h3>
                <button id="btnAddNew" class="btn btn-success btn-sm ml-auto" type="button">
                    <i class="fas fa-plus mr-1"></i> Add New Unit
                </button>
            </div>

            <div class="card-body">
                <div id="GridUnits"></div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalCreateUnit" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-md" role="document">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="fas fa-plus mr-2"></i>Register New Unit Code</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form method="post" asp-page-handler="CreateUnit">
                <div class="modal-body">
                    <div class="form-group">
                        <label class="form-label font-weight-bold">Unit Code / Symbol (e.g., VBOX)</label>
                        <input type="text" asp-for="NewUnit.Symbol" class="form-control" placeholder="Enter clean unique symbol code..." required />
                    </div>
                    <div class="form-group">
                        <label class="form-label font-weight-bold">Decimal Precision</label>
                        <input type="number" asp-for="NewUnit.DecimalPrecision" class="form-control" value="0" min="0" max="4" />
                    </div>
                    <div class="form-group">
                        <label class="form-label font-weight-bold">Unit Class Identifier</label>
                        <input type="number" asp-for="NewUnit.UnitOfMeasureClass" class="form-control" value="0" />
                    </div>
                    <div class="form-group">
                        <label class="form-label font-weight-bold">System Group Classification</label>
                        <input type="number" asp-for="NewUnit.SystemOfUnits" class="form-control" value="0" />
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary text-sm" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success text-sm px-4">Save Configuration</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            new ej.buttons.Button({ isPrimary: true }, '#btnAddNew');

            document.getElementById('btnAddNew').addEventListener('click', function () {
                $('#modalCreateUnit').modal('show');
            });

        @{
            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = null };
            var rawJson = System.Text.Json.JsonSerializer.Serialize(Model.UnitList, jsonOptions);
        }
                    var gridData = @Html.Raw(rawJson);

            var grid = new ej.grids.Grid({
                dataSource: gridData,
                allowPaging: true,
                allowSorting: true,
                allowFiltering: true,
                filterSettings: { type: 'Excel' },
                pageSettings: { pageSize: 12 },
                toolbar: ['Search'],
                editSettings: { allowEditing: true, allowDeleting: true, mode: 'Normal' },
                columns: [
                    { field: 'RecId', headerText: 'Internal RecId', width: 140, isPrimaryKey: true, visible: false },
                    { field: 'Symbol', headerText: 'Unit Code (Symbol)', width: 150, allowEditing: false }, // Symbol unique constraint shouldn't change
                    { field: 'DecimalPrecision', headerText: 'Decimal Precision', width: 140, editType: 'numericedit', textAlign: 'Right' },
                    { field: 'UnitOfMeasureClass', headerText: 'Unit Class ID', width: 130, editType: 'numericedit', textAlign: 'Center' },
                    { field: 'SystemOfUnits', headerText: 'System Group', width: 130, editType: 'numericedit', textAlign: 'Center' },
                    {
                        headerText: 'Actions', width: 120, commands: [
                            { type: 'Edit', buttonOption: { cssClass: 'e-flat e-primary', iconCss: 'e-edit e-icons' } },
                            { type: 'Delete', buttonOption: { cssClass: 'e-flat e-danger', iconCss: 'e-delete e-icons' } },
                            { type: 'Save', buttonOption: { cssClass: 'e-flat e-success', iconCss: 'e-update e-icons' } },
                            { type: 'Cancel', buttonOption: { cssClass: 'e-flat e-secondary', iconCss: 'e-cancel e-icons' } }
                        ]
                    }
                ],


                actionBegin: function (args) {
                    var token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                    if (args.requestType === 'save') {
                        fetch('?handler=UpdateUnit', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': token
                            },
                            body: JSON.stringify(args.data)
                        })
                            .then(res => res.json())
                            .then(data => {
                                if (!data.success) alert("Update failed: " + data.message);
                            });
                    }
                    else if (args.requestType === 'delete') {
                        if (confirm("Are you sure you want to delete this unit record?")) {
                            fetch('?handler=DeleteUnit', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                    'RequestVerificationToken': token
                                },
                                body: JSON.stringify(args.data[0])
                            })
                                .then(res => res.json())
                                .then(data => {
                                    if (!data.success) alert("Delete failed: " + data.message);
                                });
                        } else {
                            args.cancel = true;
                        }
                    }
                }
            });

            grid.appendTo('#GridUnits');
        });
    </script>
}