@page "{handler?}"
@model Indotalent.Pages.Syncs.LocationManagementModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    Layout = "~/Pages/Shared/AdminLTE/_Admin.cshtml";
    ViewData["Title"] = "Location Configuration Management";
    var tokens = Antiforgery.GetAndStoreTokens(HttpContext);
}

<div class="row mb-3">
    <div class="col-12 text-right">
        <button class="btn btn-success" onclick="openModalCreate()">
            <i class="fas fa-plus mr-1"></i> Add New Location
        </button>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-server mr-1"></i> Configured Sync Locations</h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover table-striped mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Location Name</th>
                            <th>Server Instance</th>
                            <th>Target Database</th>
                            <th>Auth Mode</th>
                            <th class="text-center" width="180">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Locations)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td><b>@item.Name</b></td>
                                <td><code>@item.Server</code></td>
                                <td>@item.DatabaseName</td>
                                <td>@(item.IsWindowsAuth ? "Windows Auth" : "SQL Auth (" + item.Username + ")")</td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-info mr-1" onclick="openModalEdit(@item.Id)">
                                        <i class="fas fa-edit"></i> Edit
                                    </button>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" style="display:inline;" onsubmit="return confirm('Xác nhận xóa location này?');">
                                        <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i> Del</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="mdlLocation" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-md" role="document">
        <div class="modal-content">
            <form method="post" asp-page-handler="Save" id="frmLocation">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title" id="mdlTitle">Location Card</h5>
                    <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="LocationInput.Id" id="txtId" />

                    <div class="form-group">
                        <label>Location Display Name</label>
                        <input type="text" asp-for="LocationInput.Name" id="txtName" class="form-control" required placeholder="Cửa hàng 01 (Laptop)" />
                    </div>
                    <div class="form-group">
                        <label>Server Connection Path</label>
                        <input type="text" asp-for="LocationInput.Server" id="txtServer" class="form-control" required placeholder="NOS\SQLEXPRESS hoặc 192.168.1.50" />
                    </div>
                    <div class="form-group">
                        <label>Database Name</label>
                        <input type="text" asp-for="LocationInput.DatabaseName" id="txtDb" class="form-control" required placeholder="Db_test" />
                    </div>
                    <div class="form-group">
                        <label>Authentication Type</label>
                        <select asp-for="LocationInput.IsWindowsAuth" id="ddlAuth" class="form-control" onchange="toggleAuthFields()">
                            <option value="true">Windows Authentication (Trusted_Connection)</option>
                            <option value="false">SQL Server Authentication</option>
                        </select>
                    </div>
                    <div id="sqlAuthFields" style="display:none;">
                        <div class="form-group">
                            <label>SQL Username (sa)</label>
                            <input type="text" asp-for="LocationInput.Username" id="txtUser" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>SQL Password</label>
                            <input type="password" asp-for="LocationInput.Password" id="txtPass" class="form-control" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer d-flex justify-content-between">
                    <button type="button" class="btn btn-warning" id="btnTestConnection" onclick="performTestConnection()">
                        <i class="fas fa-plug mr-1"></i> Test Connection
                    </button>
                    <div>
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleAuthFields() {
            var isWin = document.getElementById('ddlAuth').value === 'true';
            document.getElementById('sqlAuthFields').style.display = isWin ? 'none' : 'block';
        }

        function openModalCreate() {
            document.getElementById('txtId').value = 0;
            document.getElementById('txtName').value = '';
            document.getElementById('txtServer').value = '';
            document.getElementById('txtDb').value = '';
            document.getElementById('ddlAuth').value = 'true';
            document.getElementById('txtUser').value = '';
            document.getElementById('txtPass').value = '';
            document.getElementById('mdlTitle').innerText = "Add New Location Location";
            toggleAuthFields();
            $('#mdlLocation').modal('show');
        }

        function openModalEdit(id) {
            fetch('/Syncs/LocationManagement?handler=Detail&id=' + id)
                .then(r => r.json())
                .then(data => {
                    document.getElementById('txtId').value = data.Id;
                    document.getElementById('txtName').value = data.Name;
                    document.getElementById('txtServer').value = data.Server;
                    document.getElementById('txtDb').value = data.DatabaseName;
                    document.getElementById('ddlAuth').value = data.IsWindowsAuth.toString();
                    document.getElementById('txtUser').value = data.Username || '';
                    document.getElementById('txtPass').value = data.Password || '';
                    document.getElementById('mdlTitle').innerText = "Edit Configuration Location";
                    toggleAuthFields();
                    $('#mdlLocation').modal('show');
                });
        }

        function performTestConnection() {
            const btn = document.getElementById('btnTestConnection');
            const originalText = btn.innerHTML;

            // Thay đổi trạng thái nút sang loading
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Testing...';

            const payload = {
                Server: document.getElementById('txtServer').value,
                DatabaseName: document.getElementById('txtDb').value,
                IsWindowsAuth: document.getElementById('ddlAuth').value === 'true',
                Username: document.getElementById('txtUser').value,
                Password: document.getElementById('txtPass').value
            };

            fetch('/Syncs/LocationManagement?handler=TestConnection', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': '@tokens.RequestToken' // Tránh lỗi HTTP 400 Bad Request Antiforgery
                },
                body: JSON.stringify(payload)
            })
            .then(res => res.json())
            .then(data => {
                btn.disabled = false;
                btn.innerHTML = originalText;
                if(data.success) {
                    alert('🎉 ' + data.message);
                } else {
                    alert('❌ ' + data.message);
                }
            })
            .catch(err => {
                btn.disabled = false;
                btn.innerHTML = originalText;
                alert('❌ Lỗi kết nối API kiểm tra: ' + err);
            });
        }
    </script>
}