@page
@model Indotalect.Pages.Customers.CustomerLoyaltyListModel
@{
    Layout = "~/Pages/Shared/AdminLTE/_Admin.cshtml";
    ViewData["Title"] = "Loyalty Members";
}

<div class="row mb-3">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-id-card mr-1"></i> Loyalty Member List
                </h3>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3">
                        <label class="form-label">Account Number</label>
                        <input type="text" id="txtAccount" class="form-control"
                               placeholder="e.g. F0077663" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Card Number</label>
                        <input type="text" id="txtCard" class="form-control"
                               placeholder="e.g. 8110917089703" />
                    </div>
                </div>
            </div>
            <div class="">

            </div>
            <div class="card-footer">
                <button type="button" id="btnFilter" class="btn btn-primary">
                    <i class="fas fa-search mr-1"></i> Search
                </button>

                <button type="button" id="btnAll" class="btn btn-secondary">
                    <i class="fas fa-users mr-1"></i> All
                </button>
            </div>
        </div>
    </div>
</div>

<div class="card card-primary card-outline mt-3">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-table mr-1"></i> Member List
        </h3>
    </div>
    <div class="card-body">
        <div id="Grid"></div>
    </div>
</div>

@section Scripts {
    <style>
        /* ===== GRID VIỀN XANH ===== */
        .card.card-primary.card-outline {
            border-top: 3px solid #007bff !important;
        }

        .card.card-primary.card-outline .card-header {
            background-color: #f8f9fa;
            border-bottom: 1px solid #dee2e6;
        }
    </style>
    <script>
        var grid;

        document.addEventListener('DOMContentLoaded', function () {

            grid = new ej.grids.Grid({
                allowFiltering: true,
                allowSorting: true,
                allowResizing: true,
                allowPaging: true,
                allowExcelExport: true,
                allowTextWrap: true,

                filterSettings: { type: 'CheckBox' },

                pageSettings: {
                    currentPage: 1,
                    pageSize: 50,
                    pageSizes: ["20", "50", "100", "200", "All"]
                },

                showColumnMenu: true,
                gridLines: 'Horizontal',

                columns: [
                    {
                        field: 'AccountNum',
                        headerText: 'Account No.',
                        isPrimaryKey: true,
                        width: 130
                    },
                    {
                        field: 'CustomerName',
                        headerText: 'Full Name',
                        width: 200
                    },
                    {
                        field: 'IdentificationNumber',
                        headerText: 'ID Number',
                        width: 140
                    },
                    {
                        field: 'MobilePhone',
                        headerText: 'Phone',
                        width: 130
                    },
                    {
                        field: 'Email',
                        headerText: 'Email',
                        width: 180
                    },
                    {
                        field: 'BirthDate',
                        headerText: 'Birth Date',
                        width: 110,
                        textAlign: 'Center'
                    },
                    {
                        field: 'CardCount',
                        headerText: 'Cards',
                        width: 80,
                        textAlign: 'Center'
                    },
                    {
                        field: 'Cards',
                        headerText: 'Card Numbers',
                        width: 280
                    },
                    {
                        field: 'FullAddress',
                        headerText: 'Address',
                        width: 250
                    }
                ],

                toolbar: ['ExcelExport', 'Search'],

                toolbarClick: (args) => {
                    if (args.item.id === 'Grid_excelexport') {
                        grid.excelExport();
                    }
                },

                actionFailure: (args) => {
                    console.error('Grid error:', args);
                }
            });

            grid.appendTo('#Grid');

            document.getElementById('btnFilter').addEventListener('click', loadGrid);

            document.getElementById('btnAll').addEventListener('click', function () {
                document.getElementById('txtAccount').value = '';
                document.getElementById('txtCard').value = '';
                loadGrid();
            });
        });

        function loadGrid() {
            var account = document.getElementById('txtAccount').value.trim();
            var card    = document.getElementById('txtCard').value.trim();

            var params = new URLSearchParams();
            params.append('handler', 'Customers');
            if (account) params.append('AccountNumber', account);
            if (card)    params.append('CardNumber', card);

            var url = '/Customers/CustomerList?' + params.toString();

            grid.showSpinner();

            fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(r => r.json())
                .then(data => {
                    grid.dataSource = data;
                    grid.hideSpinner();
                })
                .catch(err => {
                    console.error('Load failed:', err);
                    grid.hideSpinner();
                });
        }
    </script>
}