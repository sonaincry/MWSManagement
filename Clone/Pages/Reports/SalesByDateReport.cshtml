@page
@model Indotalent.Pages.Reports.SalesByDateReportModel
@{
    Layout = "~/Pages/Shared/AdminLTE/_Admin.cshtml";
    ViewData["Title"] = "Daily Sales Report";
}

<div class="row">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-chart-bar mr-1"></i> Daily Sales Report
                </h3>
            </div>
            <div class="card-body border-bottom pb-3">
                <form method="post">
                    @Html.AntiForgeryToken()
                    <div class="row align-items-end">

                        <div class="col-md-3">
                            <label class="form-label">Store</label>
                            <input type="text"
                                   class="form-control"
                                   asp-for="StoreId"
                                   placeholder="e.g. 1001" />
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">From Date</label>
                            <input type="date"
                                   class="form-control"
                                   asp-for="StartDate"
                                   value="@Model.StartDate.ToString("yyyy-MM-dd")" />
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">To Date</label>
                            <input type="date"
                                   class="form-control"
                                   asp-for="EndDate"
                                   value="@Model.EndDate.ToString("yyyy-MM-dd")" />
                        </div>

                        <div class="col-md-3">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="fas fa-search mr-1"></i> Run Report
                            </button>
                        </div>

                    </div>
                </form>
            </div>

            <div class="card-body">
                @if (!Model.HasSearched)
                {
                    <p class="text-muted">Select filters and click Run Report.</p>
                }
                else if (!Model.ReportData.Any())
                {
                    <div class="alert alert-warning">No data found for selected range.</div>
                }
                else
                {
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <div class="info-box bg-primary">
                                <span class="info-box-icon"><i class="fas fa-calendar-day"></i></span>
                                <div class="info-box-content">
                                    <span class="info-box-text">Days with Sales</span>
                                    <span class="info-box-number">@Model.ReportData.Count</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="info-box bg-success">
                                <span class="info-box-icon"><i class="fas fa-receipt"></i></span>
                                <div class="info-box-content">
                                    <span class="info-box-text">Total Transactions</span>
                                    <span class="info-box-number">@Model.GrandTotalTransactions.ToString("N0")</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="info-box bg-warning">
                                <span class="info-box-icon"><i class="fas fa-money-bill-wave"></i></span>
                                <div class="info-box-content">
                                    <span class="info-box-text">Total Sales (VND)</span>
                                    <span class="info-box-number">@Model.GrandTotalSales.ToString("N0")</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-bordered table-hover table-sm">
                            <thead class="thead-dark">
                                <tr>
                                    <th>Date</th>
                                    <th class="text-right">Transactions</th>
                                    <th class="text-right">Total Sales</th>
                                    <th class="text-right">Avg / Transaction</th>
                                    <th class="text-center">Staff</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.ReportData.OrderBy(x => x.SalesDate))
                                {
                                    <tr>
                                        <td>@row.SalesDate.ToString("yyyy-MM-dd")</td>
                                        <td class="text-right">@row.NoOfTransactions.ToString("N0")</td>
                                        <td class="text-right">@row.TotalSales.ToString("N0")</td>
                                        <td class="text-right">@row.AvgSalesPerTransaction.ToString("N0")</td>
                                        <td class="text-center">@row.UniqueStaff</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="font-weight-bold bg-light">
                                <tr>
                                    <td><strong>TOTAL</strong></td>
                                    <td class="text-right"><strong>@Model.GrandTotalTransactions.ToString("N0")</strong></td>
                                    <td class="text-right"><strong>@Model.GrandTotalSales.ToString("N0")</strong></td>
                                    <td class="text-right">—</td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }
            </div>

        </div>
    </div>
</div>